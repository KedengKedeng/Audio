            "configurePreset": "vs17-shared",
            "configuration": "Release"
        }
    ],
    "packagePresets": [
        {
            "name": "vs18-zip",
            "displayName": "Visual Studio 2026 ZIP",
            "configurePreset": "vs18",
            "generators": ["ZIP"],
            "configurations": ["Debug", "Release"]
        },
        {
            "name": "vs17-zip",
            "displayName": "Visual Studio 2022 ZIP",
            "configurePreset": "vs17",
            "generators": ["ZIP"],
