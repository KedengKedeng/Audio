{
    "version": 6,
    "configurePresets": [
        {
            "name": "vs18",
            "hidden": true,
            "displayName": "Visual Studio 2026",
            "description": "Generator for Visual Studio 2026",
            "generator": "Visual Studio 18 2026",
            "binaryDir": "${sourceDir}/out/build/${presetName}",
            "installDir": "${sourceDir}/out/install/${presetName}"
        },
        {
            "name": "vs17",
            "hidden": true,
            "displayName": "Visual Studio 2022",
            "description": "Generator for Visual Studio 2022",
            "generator": "Visual Studio 17 2022",
            "binaryDir": "${sourceDir}/out/build/${presetName}",
            "installDir": "${sourceDir}/out/install/${presetName}"
        },
        {
            "name": "ninja",
            "hidden": true,
            "displayName": "Ninja",
            "description": "Generator for Ninja build system",
            "generator": "Ninja Multi-Config",
            "binaryDir": "${sourceDir}/out/build/${presetName}",
            "installDir": "${sourceDir}/out/install/${presetName}"
        },
        {
            "name": "vs18-static",
            "displayName": "Visual Studio 2026 (Static)",
            "description": "Generator for Visual Studio 2026 with static libraries",
            "inherits": "vs18"
        },
        {
            "name": "vs18-shared",
            "displayName": "Visual Studio 2026 (Shared)",
            "description": "Generator for Visual Studio 2026 with shared libraries",
            "inherits": "vs18",
            "cacheVariables": {
                "BUILD_SHARED_LIBS": "ON"
            }
        },
        {
            "name": "vs17-static",
            "displayName": "Visual Studio 2022 (Static)",
            "description": "Generator for Visual Studio 2022 with static libraries",
            "inherits": "vs17"
        },
        {
            "name": "vs17-shared",
            "displayName": "Visual Studio 2022 (Shared)",
            "description": "Generator for Visual Studio 2022 with shared libraries",
            "inherits": "vs17",
            "cacheVariables": {
                "BUILD_SHARED_LIBS": "ON"
            }
        },
        {
            "name": "ninja-static",
            "displayName": "Ninja (Static)",
            "description": "Generator for Ninja build system with static libraries",
            "inherits": "ninja"
        },
        {
            "name": "ninja-shared",
            "displayName": "Ninja (Shared)",
            "description": "Generator for Ninja build system with shared libraries",
            "inherits": "ninja",
            "cacheVariables": {
                "BUILD_SHARED_LIBS": "ON"
            }
        },
        {
            "name": "clang-static",
            "displayName": "Clang (Static)",
            "generator": "Unix Makefiles",
            "binaryDir": "${sourceDir}/out/build/${presetName}",
            "installDir": "${sourceDir}/out/install/${presetName}",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release",
                "CMAKE_C_COMPILER": "clang",
                "CMAKE_CXX_COMPILER": "clang++"
            }
        },
        {
            "name": "clang-shared",
            "displayName": "Clang (Shared)",
            "generator": "Unix Makefiles",
            "binaryDir": "${sourceDir}/out/build/${presetName}",
            "installDir": "${sourceDir}/out/install/${presetName}",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release",
                "CMAKE_C_COMPILER": "clang",
                "CMAKE_CXX_COMPILER": "clang++",
                "BUILD_SHARED_LIBS": "ON"
            }
        }
    ],
    "buildPresets": [
        {
            "name": "vs18-static-debug",
            "displayName": "Visual Studio 2026 Static Debug",
            "description": "Debug build using Visual Studio 2026 (static)",
            "configurePreset": "vs18-static",
            "configuration": "Debug"
        },
        {
            "name": "vs18-static-release",
            "displayName": "Visual Studio 2026 Static Release",
