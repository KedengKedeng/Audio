        },
        {
            "name": "clang-shared-release",
            "displayName": "Clang Shared Release",
            "configurePreset": "clang-shared",
            "configuration": "Release"
        }
    ],
    "packagePresets": [
        {
            "name": "vs18-static-zip",
            "displayName": "Visual Studio 2026 Static ZIP",
            "configurePreset": "vs18-static",
            "generators": ["ZIP"],
            "configurations": ["Debug", "Release"]
        },
        {
            "name": "vs18-shared-zip",
            "displayName": "Visual Studio 2026 Shared ZIP",
            "configurePreset": "vs18-shared",
            "generators": ["ZIP"],
            "configurations": ["Debug", "Release"]
        },
        {
            "name": "vs17-static-zip",
